# Application Settings
APP_NAME=FL-DP Healthcare CKD Prediction
APP_VERSION=1.0.0
DEBUG=True

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./App/database/app.db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# File Upload
UPLOAD_DIR=./App/uploads
MAX_UPLOAD_SIZE=10485760

# ML Model Paths
TEMPLATE_CSV=./FL-DP-Healthcare/data/chronic_kidney_disease_5000.csv
SERVER_DIR=./FL-DP-Healthcare/server
CLIENTS_BASE_DIR=./FL-DP-Healthcare

# Training Defaults
DEFAULT_EPOCHS=30
DEFAULT_BATCH_SIZE=64
DEFAULT_LEARNING_RATE=0.001
DEFAULT_LOCAL_EPOCHS=10
DEFAULT_MAX_GRAD_NORM=1.0
DEFAULT_NOISE_MULTIPLIER=0.8